<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WenshuApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_container</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="divider">@color/divider</item>
        <item name="rippleColor">@color/ripple_color</item>
        <item name="buttonStyle">@style/WenshuButton</item>
        <item name="textInputStyle">@style/WenshuInput</item>
        <item name="cardViewStyle">@style/WenshuCard</item>
        <item name="chipStyle">@style/WenshuChip</item>
    </style>

    <style name="Theme.WenshuApp.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="WenshuButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_black</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:height">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/ripple_color</item>
    </style>

    <style name="WenshuButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/button_outline_stroke</item>
        <item name="strokeWidth">@dimen/stroke_width</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:height">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/ripple_color</item>
    </style>

    <style name="WenshuButton.White" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_white</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:height">@dimen/small_button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">@dimen/stroke_width</item>
    </style>

    <style name="WenshuButton.Small" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_black</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">@dimen/small_button_radius</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:height">@dimen/small_button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="rippleColor">@color/ripple_color</item>
    </style>

    <style name="WenshuInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxStrokeWidth">@dimen/stroke_width</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="WenshuCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/post_card_elevation</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="WenshuChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="chipCornerRadius">@dimen/chip_radius</item>
        <item name="chipMinHeight">32dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="rippleColor">@color/ripple_color</item>
    </style>

    <style name="ChipSelected">
        <item name="chipBackgroundColor">@color/chip_selected_background</item>
        <item name="android:textColor">@color/chip_selected_text</item>
    </style>

    <style name="WenshuText.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="WenshuText.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="WenshuText.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="WenshuText.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="WenshuText.Micro" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_micro</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/background</item>
        <item name="itemIconTint">@color/nav_icon_color_selector</item>
        <item name="itemTextColor">@color/nav_icon_color_selector</item>
        <item name="elevation">@dimen/stroke_width</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@color/ripple_color</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="ToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="android:elevation">0dp</item>
    </style>
</resources>
