<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="跳过"
        android:textColor="@color/text_tertiary"
        android:textSize="15sp"
        android:fontFamily="serif"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="绑定手机号"
        android:textColor="@color/ink"
        android:textSize="28sp"
        android:fontFamily="serif"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/tv_skip"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="绑定手机号可用于找回密码、接收重要通知"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <View
        android:id="@+id/view_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_phone"
        style="@style/WenshuInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="请输入手机号"
        app:layout_constraintTop_toBottomOf="@id/view_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:boxCornerRadiusTopStart="2dp"
        app:boxCornerRadiusTopEnd="2dp"
        app:boxCornerRadiusBottomStart="2dp"
        app:boxCornerRadiusBottomEnd="2dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/paper"
            android:fontFamily="serif"
            android:inputType="phone"
            android:maxLength="11"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_code"
        style="@style/WenshuInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="请输入验证码"
        app:layout_constraintTop_toBottomOf="@id/til_phone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:boxCornerRadiusTopStart="2dp"
        app:boxCornerRadiusTopEnd="2dp"
        app:boxCornerRadiusBottomStart="2dp"
        app:boxCornerRadiusBottomEnd="2dp"
        app:endIconMode="custom">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/paper"
            android:fontFamily="serif"
            android:inputType="number"
            android:maxLength="6"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/btn_send_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="获取验证码"
        android:textColor="@color/ink"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="@id/til_code"
        app:layout_constraintBottom_toBottomOf="@id/til_code"
        app:layout_constraintEnd_toEndOf="@id/til_code"
        android:layout_marginEnd="8dp" />

    <Button
        android:id="@+id/btn_bind"
        style="@style/WenshuButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="绑 定"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/til_code"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/seal"
        android:textSize="13sp"
        android:fontFamily="serif"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btn_bind"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
