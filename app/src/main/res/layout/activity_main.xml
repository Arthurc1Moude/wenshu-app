<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        style="@style/BottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_icon_color_selector"
        app:itemTextColor="@color/nav_icon_color_selector"
        app:labelVisibilityMode="labeled" />

    <LinearLayout
        android:id="@+id/notification_popup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ink"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:elevation="8dp"
        android:visibility="gone"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/notif_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_online"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/notif_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/on_primary"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notif_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="查看"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
