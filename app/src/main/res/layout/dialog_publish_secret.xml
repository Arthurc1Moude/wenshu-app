<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="@dimen/spacing_lg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="秘帖内容">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textMultiLine" android:minLines="4" android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:text="可见范围" android:textColor="@color/text_primary" android:textSize="@dimen/text_body" android:fontFamily="serif" />
        <RadioGroup android:id="@+id/rg_visibility" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_sm">
            <RadioButton android:id="@+id/rb_private" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="仅自己可见" android:checked="true" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/rb_mutual" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="仅互关好友可见" android:textColor="@color/text_primary" />
            <RadioButton android:id="@+id/rb_specified" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="仅指定的人可见" android:textColor="@color/text_primary" />
        </RadioGroup>
    </LinearLayout>
</ScrollView>
